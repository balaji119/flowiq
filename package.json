{
  "name": "flowiq",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared",
    "packages/ui"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @flowiq/web",
    "start": "npm run dev",
    "web": "npm run dev --workspace @flowiq/web",
    "dev:api": "go -C apps/api run .",
    "start:api": "go -C apps/api run .",
    "start:all": "concurrently \"npm run web\" \"npm run dev:api\"",
    "build": "npm run build --workspace @flowiq/web && go -C apps/api build .",
    "serve": "npm run serve --workspace @flowiq/web",
    "typecheck": "npm run typecheck --workspace @flowiq/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
