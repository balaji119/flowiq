{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@flowiq/shared": ["../../packages/shared/src/index.ts"],
      "@flowiq/shared/*": ["../../packages/shared/src/*"],
      "@flowiq/ui": ["../../packages/ui/src/index.ts"],
      "@flowiq/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
