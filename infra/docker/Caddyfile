{
  servers {
    # Disable HTTP/3 (QUIC) because some networks/browsers intermittently fail
    # large streamed downloads with ERR_QUIC_PROTOCOL_ERROR.
    protocols h1 h2
  }
}

:80 {
  @compressible not path /api/campaign-images/* /campaign-files/*
  encode @compressible zstd gzip

  handle_path /campaign-files/* {
    root * /shared-storage/uploads/campaign-images
    header {
      Cache-Control "private, no-store, no-transform"
      X-Content-Type-Options nosniff
    }
    file_server
  }

  @api path /api/*
  handle @api {
    reverse_proxy api:4000
  }

  handle {
    reverse_proxy web:3000
  }

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }
}
