FROM node:22-bookworm-slim

WORKDIR /workspace

ENV NEXT_TELEMETRY_DISABLED=1

# Install workspace dependencies first for better layer caching.
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages/shared/package.json ./packages/shared/package.json
COPY packages/ui/package.json ./packages/ui/package.json
RUN npm ci

# Copy the full monorepo because the web app depends on local workspaces.
COPY . .

RUN npm run build --workspace @flowiq/web

ENV NODE_ENV=production

EXPOSE 3000

CMD ["npm", "run", "serve", "--workspace", "@flowiq/web"]
